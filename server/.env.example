# Eva Insight server config

# Port the proxy listens on
PORT=8787

# Anthropic API key (Phase 1+)
ANTHROPIC_API_KEY=

# Bearer token the extension must send (Phase 1; replaced by device pairing in Phase 6)
# Generate a fresh value, e.g.:  openssl rand -hex 32
EVA_INSIGHT_SHARED_SECRET=change-me-in-dev

# Comma-separated allowed origins for CORS.
# Default targets the current dev install of the extension.
EVA_INSIGHT_ALLOWED_ORIGINS=chrome-extension://kkjnkjiclpmfkadlmjkjednknilknnhl

# Default Claude model used when the client omits `model`.
EVA_INSIGHT_DEFAULT_MODEL=claude-opus-4-6
